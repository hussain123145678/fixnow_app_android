# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MAPS_API_KEY: Required for Google Maps Android SDK representation.
# Provide your key in the AI Studio Secrets panel during development or production.
MAPS_API_KEY=YOUR_NATIVE_MAPS_API_KEY_HERE

# SUPABASE_URL: The base API URL for your Supabase project (e.g., https://yourproject.supabase.co)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE

# SUPABASE_ANON_KEY: The public anonymous API key for your Supabase project
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# MAPBOX_ACCESS_TOKEN: Your Mapbox API access token for maps, geocoding and routing
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoiZmRldm0iLCJhIjoiY2x0eXZ5c2E4MDBoODJqbG5tdzM0eDN4YSJ9.your_token_here

# GOOGLE_WEB_CLIENT_ID: Your Google Cloud Web Client ID for Android Google Sign-In
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_HERE


